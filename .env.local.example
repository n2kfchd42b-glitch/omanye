# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ────────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key

# Stripe webhook secret — generated when registering the webhook endpoint
# Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ── Stripe Price IDs ──────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Products → select plan → Pricing
NEXT_PUBLIC_STRIPE_STARTER_MONTHLY=price_your-starter-monthly-id
NEXT_PUBLIC_STRIPE_STARTER_ANNUAL=price_your-starter-annual-id
NEXT_PUBLIC_STRIPE_PRO_MONTHLY=price_your-professional-monthly-id
NEXT_PUBLIC_STRIPE_PRO_ANNUAL=price_your-professional-annual-id

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL used by smoke tests, CORS allowed origins, and absolute redirects
# In production set to your canonical domain: https://omanye.io
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of hosts allowed to invoke Server Actions (no protocol, no slash)
# In production: NEXT_PUBLIC_ALLOWED_HOSTS=omanye.io,www.omanye.io
NEXT_PUBLIC_ALLOWED_HOSTS=localhost:3000

# ── Contact emails ────────────────────────────────────────────────────────────
# Displayed on the marketing contact page
NEXT_PUBLIC_CONTACT_EMAIL_GENERAL=hello@omanye.io
NEXT_PUBLIC_CONTACT_EMAIL_SALES=sales@omanye.io
NEXT_PUBLIC_CONTACT_EMAIL_SUPPORT=support@omanye.io

# ── Supabase Edge Function Secrets ────────────────────────────────────────────
# These are NOT set in .env.local — they are Supabase Edge Function secrets.
# Set them in: Supabase Dashboard → Edge Functions → Manage secrets
#
# RESEND_API_KEY=re_your-resend-api-key       # Resend API key for transactional email
# SITE_URL=https://omanye.io                  # Absolute base URL used in email links
# FROM_EMAIL=noreply@omanye.io                # Sender address for all outbound emails
#
# Used by: send-donor-invitation, send-team-invitation edge functions
